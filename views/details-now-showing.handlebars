<section class="details">

    <div class="movie-card__details">
        <li class="movie-card__details__poster" style="background-image: url({{details.Poster}});"></li>
        
        <div class="movie-card__details__info">
            <h2>{{details.Title}}</h2>
            <p><em>{{details.Plot}}</em></p>
            <p>Starring: {{details.Actors}}</p>
            <p>Director: {{details.Director}}</p>
            <p>Year: {{details.Year}}</p>
            <p>Genre: {{details.Genre}}</p>
            <p>Rated: {{details.Rated}}</p>
            {{#each details.Ratings}}
                <p>{{this.Source}}: {{this.Value}}</p>
            {{/each}}
            <div class="movie-card__details__btns">
                <form action="/movies" method="GET">
                    <button class="btn" type="submit">Back</button>
                </form>
                <form action="/movies/{{details._id}}?_method=DELETE" method="POST">
                    <button class="btn-remove" type="submit">Remove</button>
                </form>
                <div class="rating">
                    <input type="radio" id="star5" name="rating" value="5" /><label for="star5"></label>
                    <input type="radio" id="star4" name="rating" value="4" /><label for="star4"></label>
                    <input type="radio" id="star3" name="rating" value="3" /><label for="star3"></label>
                    <input type="radio" id="star2" name="rating" value="2" /><label for="star2"></label>
                    <input type="radio" id="star1" name="rating" value="1" /><label for="star1"></label>
                </div>
            </div>
        </div>
    </div>

</section>